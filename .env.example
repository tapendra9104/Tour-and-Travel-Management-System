# Copy values from this file into your hosting provider or local shell.
# Do not commit real secrets. Rename this file to .env for local use.

# ─── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Public App URL ────────────────────────────────────────────────────────────
# Used in emails (password reset links), sitemap, and robots.txt.
# MUST be set to your public domain in production.
APP_BASE_URL=http://localhost:8080

# ─── MySQL Database ────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/wanderlust?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=wanderlust
DB_PASSWORD=wanderlust

# ─── SMTP Email Delivery ───────────────────────────────────────────────────────
# Without SMTP, notifications are stored in the DB but not emailed.
# Password reset emails REQUIRE SMTP + APP_BASE_URL to work end-to-end.
#
# Gmail example (use an App Password, not your account password):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=you@gmail.com
#   MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx   # 16-char App Password from Google Account
#
# Brevo / Sendinblue example:
#   MAIL_HOST=smtp-relay.brevo.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-brevo-login@example.com
#   MAIL_PASSWORD=your-brevo-smtp-key
#
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@wanderlust.com
ADMIN_EMAIL=admin@wanderlust.com
SUPPORT_EMAIL=hello@wanderlust.com

# ─── Seed Accounts ─────────────────────────────────────────────────────────────
# In production: set SEED_ADMIN_PASSWORD to create an initial admin on first boot.
# Disable traveler seed and demo credentials in production.
SEED_ADMIN_ENABLED=true
SEED_ADMIN_EMAIL=admin@wanderlust.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Wanderlust Admin
SEED_TRAVELER_ENABLED=true
SEED_TRAVELER_EMAIL=traveler@wanderlust.com
SEED_TRAVELER_PASSWORD=Traveler@123
SEED_TRAVELER_NAME=Demo Traveler
DEMO_CREDENTIALS_ENABLED=true

# ─── Payment Policy ────────────────────────────────────────────────────────────
PAYMENT_CURRENCY=USD
PAYMENT_DEPOSIT_RATE=0.30
PAYMENT_FULL_WINDOW_DAYS=45
PAYMENT_BALANCE_DUE_DAYS=21

# ─── Payment Gateway ───────────────────────────────────────────────────────────
# Options: sandbox (default, no real charges) | stripe (real payments)
# To enable Stripe:
#   1. Set PAYMENT_GATEWAY=stripe
#   2. Add the Stripe SDK to pom.xml (see StripePaymentGateway.java for instructions)
#   3. Set STRIPE_SECRET_KEY to your Stripe secret key
PAYMENT_GATEWAY=sandbox
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Swagger / OpenAPI UI ──────────────────────────────────────────────────────
# Available at /swagger-ui.html when enabled.
# Set to false in production if you do not want API docs publicly browsable.
SPRINGDOC_ENABLED=true
